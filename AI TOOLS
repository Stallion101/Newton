import React, { useState, useEffect, useRef } from "react";
import { 
  Sparkles, 
  BookOpen, 
  CircleDot, 
  Layers, 
  BookMarked, 
  Theater, 
  Mail, 
  Search,
  Calculator,
  Type,
  FileText,
  Brain,
  ChevronRight
} from "lucide-react";
import PageHeader from "../components/shared/PageHeader";

// Import tool components
import ParagraphShrinking from "../components/tools/ParagraphShrinking";
import TouchPointMathLab from "../components/tools/TouchPointMathLab";
import ClozePassageGenerator from "../components/tools/ClozePassageGenerator";
import VisualVocalPhonicsLab from "../components/tools/VisualVocalPhonicsLab";
import MathWorksheetGenerator from "../components/tools/MathWorksheetGenerator";
import MathInterventionCreator from "../components/tools/MathInterventionCreator";
import MathCBMGenerator from "../components/tools/MathCBMGenerator";
import DramaScriptGenerator from "../components/tools/DramaScriptGenerator";
import SocialStoryCreator from "../components/tools/SocialStoryCreator";

// Pointing to the file where we pasted the new Sight Word Lab code
import SightWordLab from "../components/tools/sightword/ColorByWordActivity"; 

import SightWordChecker from "../components/tools/SightWordChecker";
import DecodablePassageGenerator from "../components/tools/DecodablePassageGenerator";
import ABAToolkit from "../components/tools/ABAToolkit";
import ElkoninBoxesGenerator from "../components/tools/ElkoninBoxesGenerator";
import SyllableStudio from "../components/tools/SyllableStudio";
import VocabularyBuilder from "../components/tools/VocabularyBuilder";
import SummaryStepLadder from "../components/tools/SummaryStepLadder";
import OrganizerArchitect from "../components/tools/OrganizerArchitect";
import InferenceDetective from "../components/tools/InferenceDetective";
import MentalMovieDirector from "../components/tools/MentalMovieDirector";
import SignalWordPredictor from "../components/tools/SignalWordPredictor";

const TOOLS = [
  // LITERACY
  { id: "decodable", label: "Decodable Passage", icon: BookOpen, category: "Literacy" },
  { id: "elkonin", label: "Elkonin Box Builder", icon: CircleDot, category: "Literacy" },
  { id: "syllable", label: "Syllable Studio", icon: Layers, category: "Literacy" },
  { id: "vocabulary", label: "Vocabulary Lab", icon: BookMarked, category: "Literacy" },
  // RE-ADDED: sightword entry so it appears in the sidebar
  { id: "sightword", label: "Sight Word Lab", icon: Type, category: "Literacy" },
  { id: "cloze", label: "Cloze Passage", icon: FileText, category: "Literacy" },
  // MATH
  { id: "touchpoint", label: "TouchPoint Math", icon: Calculator, category: "Math" },
  { id: "worksheet", label: "Math Worksheets", icon: FileText, category: "Math" },
  { id: "cbm", label: "Math CBM Gen", icon: Calculator, category: "Math" },
  // SEL & BEHAVIOR
  { id: "socialstory", label: "Social Stories", icon: Brain, category: "SEL & Behavior" },
  { id: "aba", label: "ABA Toolkit", icon: Brain, category: "SEL & Behavior" },
  // ARTS & ADMIN
  { id: "drama", label: "Drama Scripts", icon: Theater, category: "Specialty" },
  { id: "communication", label: "Parent Emails", icon: Mail, category: "Admin" },
];

const TOOL_COMPONENTS = {
  decodable: DecodablePassageGenerator,
  elkonin: ElkoninBoxesGenerator,
  syllable: SyllableStudio,
  vocabulary: VocabularyBuilder,
  sightword: SightWordLab,
  cloze: ClozePassageGenerator,
  touchpoint: TouchPointMathLab,
  worksheet: MathWorksheetGenerator,
  socialstory: SocialStoryCreator,
  drama: DramaScriptGenerator,
  parashrink: ParagraphShrinking,
  visualvocal: VisualVocalPhonicsLab,
  intervention: MathInterventionCreator,
  cbm: MathCBMGenerator,
  aba: ABAToolkit,
  summary: SummaryStepLadder,
  organizer: OrganizerArchitect,
  inference: InferenceDetective,
  mentalmovie: MentalMovieDirector,
  signalword: SignalWordPredictor,
};

export default function AITools() {
  const [selectedTool, setSelectedTool] = useState(null);
  const [searchQuery, setSearchQuery] = useState("");
  const workspaceRef = useRef(null);

  useEffect(() => {
    if (selectedTool) {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  }, [selectedTool]);

  const filteredTools = TOOLS.filter(tool => 
    tool.label.toLowerCase().includes(searchQuery.toLowerCase())
  );

  const categories = [...new Set(TOOLS.map(t => t.category))];
  const SelectedToolComponent = selectedTool ? TOOL_COMPONENTS[selectedTool] : null;

  return (
    <div className="flex flex-col lg:flex-row gap-8 min-h-screen">
      {/* Sidebar */}
      <div className="w-full lg:w-80 flex flex-col gap-6">
        <div className="bg-white p-4 rounded-3xl shadow-sm border border-border/50 sticky top-8">
          <div className="relative mb-6">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
            <input 
              type="text"
              placeholder="Search tools..."
              className="w-full pl-10 pr-4 py-2 bg-slate-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-newton-pink/20 transition-all"
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
            />
          </div>

          <div className="space-y-6 max-h-[75vh] overflow-y-auto pr-2 custom-scrollbar">
            {categories.map(category => {
              const categoryTools = filteredTools.filter(t => t.category === category);
              if (categoryTools.length === 0) return null;

              return (
                <div key={category} className="space-y-2">
                  <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-[0.15em] px-3">
                    {category}
                  </h4>
                  <div className="space-y-1">
                    {categoryTools.map((tool) => {
                      const Icon = tool.icon;
                      return (
                        <button
                          key={tool.id}
                          onClick={() => setSelectedTool(tool.id)}
                          className={`w-full flex items-center justify-between px-4 py-2.5 rounded-xl text-sm font-bold transition-all ${
                            selectedTool === tool.id 
                              ? "bg-newton-pink text-white shadow-md shadow-newton-pink/20" 
                              : "text-slate-500 hover:bg-newton-pink/5 hover:text-newton-pink"
                          }`}
                        >
                          <div className="flex items-center gap-3">
                            <Icon className={`w-4 h-4 ${selectedTool === tool.id ? "text-white" : "text-slate-400"}`} />
                            {tool.label}
                          </div>
                          {selectedTool === tool.id && <ChevronRight className="w-3 h-3 text-white/70" />}
                        </button>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      {/* Main Workspace */}
      <div className="flex-1 min-w-0" ref={workspaceRef}>
        {!selectedTool ? (
          <div className="bg-white rounded-[2.5rem] border border-dashed border-slate-200 p-12 text-center h-[70vh] flex flex-col items-center justify-center shadow-sm">
            <div className="w-24 h-24 bg-newton-pink/5 rounded-[2rem] flex items-center justify-center mb-6 animate-pulse">
              <Sparkles className="w-12 h-12 text-newton-pink" />
            </div>
            <h2 className="text-3xl font-display font-black text-slate-800 mb-3 tracking-tight">
              THE NEWTON LAB
            </h2>
            <p className="text-slate-400 max-w-md mx-auto leading-relaxed font-medium">
              Your multi-disciplinary workspace for specialized instruction. 
              Select a builder to begin creating materials for 
              <span className="text-slate-600 font-bold"> Literacy, Math, SEL, and Drama.</span>
            </p>
          </div>
        ) : (
          <div className="bg-white rounded-[2.5rem] border border-border/50 shadow-sm p-8 min-h-[80vh] animate-in fade-in zoom-in-95 duration-500">
            {SelectedToolComponent ? (
              <SelectedToolComponent />
            ) : (
              <div className="flex flex-col items-center justify-center h-full text-center py-20">
                <Brain className="w-12 h-12 text-slate-200 mb-4" />
                <h3 className="text-lg font-bold text-slate-400">Tool Under Construction</h3>
                <p className="text-sm text-slate-300">We are currently migrating this component to the new Lab framework.</p>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
