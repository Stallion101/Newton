import { useState, useEffect, useRef } from "react";
import { base44 } from "@/api/base44Client";
import { BookOpen, Send, User, Sparkles, ChevronDown } from "lucide-react";
import { Button } from "@/components/ui/button";
import ReactMarkdown from "react-markdown";

const NAVY = "#1A2B3C";
const SAGE = "#76B5B3";

const STARTER_PROMPTS = [
  "Create a CVC passage about dinosaurs for a Kindergartner",
  "Write a blends (sl, cl, bl) passage for a 1st grader who loves space",
  "Make a long vowel silent-e passage for a student named Maya who likes horses",
  "Generate a digraph (sh, ch, th) decodable text for a soccer fan in Grade 1",
];

export default function DecodableAgent() {
  const [conversation, setConversation] = useState(null);
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState("");
  const [sending, setSending] = useState(false);
  const [students, setStudents] = useState([]);
  const [selectedStudent, setSelectedStudent] = useState("");
  const bottomRef = useRef(null);

  useEffect(() => {
    base44.entities.Student.list().then(setStudents).catch(() => {});
    initConversation();
  }, []);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  async function initConversation() {
    const convo = await base44.agents.createConversation({
      agent_name: "decodable_passage_agent",
      metadata: { name: "Decodable Passage Session" },
    });
    setConversation(convo);
    setMessages(convo.messages || []);

    const unsubscribe = base44.agents.subscribeToConversation(convo.id, (data) => {
      setMessages(data.messages || []);
    });
    return () => unsubscribe();
  }

  async function sendMessage(text) {
    if (!text.trim() || !conversation || sending) return;
    setSending(true);
    setInput("");

    // Prefix with student context if selected
    let finalText = text;
    if (selectedStudent) {
      const student = students.find(s => s.name === selectedStudent);
      if (student) {
        finalText = `[Student context: ${student.name}, Grade: ${student.grade || "unknown"}, Fluency: ${student.fluency_wpm || "?"}WPM]\n\n${text}`;
      }
    }

    await base44.agents.addMessage(conversation, { role: "user", content: finalText });
    setSending(false);
  }

  function handleKeyDown(e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage(input);
    }
  }

  const displayMessages = messages.filter(m => m.role !== "system");

  return (
    <div className="max-w-3xl mx-auto space-y-6">
      {/* Header */}
      <div className="flex items-center gap-3">
        <div className="w-12 h-12 rounded-xl flex items-center justify-center" style={{ background: `linear-gradient(135deg, ${NAVY}, ${SAGE})` }}>
          <BookOpen className="w-6 h-6 text-white" />
        </div>
        <div>
          <h1 className="text-2xl font-display font-bold" style={{ color: NAVY }}>Decodable Passage Agent</h1>
          <p className="text-sm text-muted-foreground">AI-powered phonics passage generator tailored to each student</p>
        </div>
        <span className="ml-auto px-3 py-1 rounded-full text-xs font-semibold text-white" style={{ background: SAGE }}>
          🤖 AI Agent
        </span>
      </div>

      {/* Student Quick-Select */}
      <div className="bg-white rounded-2xl border border-border/40 p-4 flex items-center gap-4 shadow-sm">
        <User className="w-4 h-4 text-muted-foreground shrink-0" />
        <div className="flex-1">
          <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">Personalize for a Student (optional)</p>
          <div className="relative">
            <select
              value={selectedStudent}
              onChange={e => setSelectedStudent(e.target.value)}
              className="w-full text-sm rounded-lg border border-border/60 bg-secondary/20 px-3 py-2 pr-8 focus:outline-none focus:ring-1 appearance-none"
            >
              <option value="">— No student selected —</option>
              {students.map(s => (
                <option key={s.id} value={s.name}>{s.name} ({s.grade || "Grade ?"})</option>
              ))}
            </select>
            <ChevronDown className="absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground pointer-events-none" />
          </div>
        </div>
        {selectedStudent && (
          <span className="px-2 py-1 rounded-full text-xs font-semibold" style={{ background: `${SAGE}20`, color: SAGE }}>
            ✓ Context will be sent
          </span>
        )}
      </div>

      {/* Starter Prompts */}
      {displayMessages.length === 0 && (
        <div className="bg-white rounded-2xl border border-border/40 p-5 shadow-sm">
          <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-3 flex items-center gap-1.5">
            <Sparkles className="w-3.5 h-3.5" /> Try a starter prompt
          </p>
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {STARTER_PROMPTS.map((p, i) => (
              <button
                key={i}
                onClick={() => sendMessage(p)}
                disabled={!conversation || sending}
                className="text-left text-sm px-3 py-2.5 rounded-xl border border-border/50 hover:border-border hover:bg-secondary/30 transition-all text-muted-foreground hover:text-foreground"
              >
                {p}
              </button>
            ))}
          </div>
        </div>
      )}

      {/* Chat Window */}
      <div className="bg-white rounded-2xl border border-border/40 shadow-sm overflow-hidden flex flex-col" style={{ minHeight: 400 }}>
        <div className="flex-1 overflow-y-auto p-5 space-y-4" style={{ maxHeight: 520 }}>
          {displayMessages.length === 0 && !sending && (
            <div className="flex flex-col items-center justify-center py-16 text-center">
              <div className="w-14 h-14 rounded-2xl flex items-center justify-center mb-3" style={{ background: `${NAVY}12` }}>
                <BookOpen className="w-7 h-7" style={{ color: NAVY }} />
              </div>
              <p className="font-semibold" style={{ color: NAVY }}>Ready to craft a passage</p>
              <p className="text-sm text-muted-foreground mt-1 max-w-xs">Describe the student's phonics level or pick a starter prompt above.</p>
            </div>
          )}

          {displayMessages.map((msg, i) => (
            <MessageBubble key={i} message={msg} />
          ))}

          {sending && (
            <div className="flex items-center gap-3">
              <div className="w-7 h-7 rounded-lg flex items-center justify-center" style={{ background: `${NAVY}15` }}>
                <div className="w-1.5 h-1.5 rounded-full" style={{ background: NAVY }} />
              </div>
              <div className="flex gap-1">
                {[0, 1, 2].map(j => (
                  <div key={j} className="w-2 h-2 rounded-full animate-bounce" style={{ background: SAGE, animationDelay: `${j * 0.15}s` }} />
                ))}
              </div>
            </div>
          )}

          <div ref={bottomRef} />
        </div>

        {/* Input */}
        <div className="border-t border-border/30 p-4 flex gap-3">
          <textarea
            value={input}
            onChange={e => setInput(e.target.value)}
            onKeyDown={handleKeyDown}
            placeholder="Describe the phonics focus, grade level, or student interest…"
            rows={2}
            className="flex-1 resize-none rounded-xl border border-border/60 bg-secondary/20 px-3 py-2 text-sm focus:outline-none focus:ring-1 transition-all"
            style={{ fontFamily: "var(--font-inter)" }}
          />
          <Button
            onClick={() => sendMessage(input)}
            disabled={!input.trim() || !conversation || sending}
            className="rounded-xl self-end px-4 py-2 gap-1.5"
            style={{ backgroundColor: NAVY, color: "white", minHeight: 40 }}
          >
            <Send className="w-4 h-4" /> Send
          </Button>
        </div>
      </div>
    </div>
  );
}

function MessageBubble({ message }) {
  const NAVY = "#1A2B3C";
  const SAGE = "#76B5B3";
  const isUser = message.role === "user";
  // Strip injected student context prefix from display
  const displayContent = isUser
    ? message.content.replace(/^\[Student context:.*?\]\n\n/s, "")
    : message.content;

  return (
    <div className={`flex gap-3 ${isUser ? "justify-end" : "justify-start"}`}>
      {!isUser && (
        <div className="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 mt-0.5" style={{ background: `${NAVY}15` }}>
          <div className="w-1.5 h-1.5 rounded-full" style={{ background: NAVY }} />
        </div>
      )}
      <div className={`max-w-[85%] rounded-2xl px-4 py-3 ${isUser ? "text-white" : "bg-white border border-border/40"}`}
        style={isUser ? { backgroundColor: NAVY } : {}}>
        {isUser ? (
          <p className="text-sm leading-relaxed">{displayContent}</p>
        ) : (
          <ReactMarkdown
            className="text-sm prose prose-sm max-w-none [&>*:first-child]:mt-0 [&>*:last-child]:mb-0"
            components={{
              strong: ({ children }) => <strong style={{ color: SAGE }}>{children}</strong>,
              p: ({ children }) => <p className="my-1 leading-relaxed">{children}</p>,
              ul: ({ children }) => <ul className="my-1 ml-4 list-disc">{children}</ul>,
              ol: ({ children }) => <ol className="my-1 ml-4 list-decimal">{children}</ol>,
              li: ({ children }) => <li className="my-0.5">{children}</li>,
              h1: ({ children }) => <h1 className="text-base font-bold my-2" style={{ color: NAVY }}>{children}</h1>,
              h2: ({ children }) => <h2 className="text-sm font-bold my-2" style={{ color: NAVY }}>{children}</h2>,
              h3: ({ children }) => <h3 className="text-sm font-semibold my-1" style={{ color: NAVY }}>{children}</h3>,
            }}
          >
            {displayContent}
          </ReactMarkdown>
        )}
      </div>
    </div>
  );
}
