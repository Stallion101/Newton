import React, { useState } from 'react';
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { toast } from "sonner";
import { generateAIContent } from "@/lib/ai";

export default function DecodablePassageGenerator() {
  // 1. Initialize as empty array to remove Gregory, Sofia, and Liam
  const [students, setStudents] = useState([]); 
  const [selectedStudent, setSelectedStudent] = useState(null);
  const [grade, setGrade] = useState("Kindergarten");
  const [focusSounds, setFocusSounds] = useState("");
  const [interest, setInterest] = useState("");
  const [result, setResult] = useState("");
  const [generating, setGenerating] = useState(false);

  async function handleGenerate() {
    if (!interest.trim()) {
      toast.error("Please enter a student interest or theme.");
      return;
    }

    setGenerating(true);
    setResult("");

    // 2. Optional student logic: use name if selected, otherwise generic
    const studentContext = selectedStudent 
      ? `a ${grade} student named ${selectedStudent.firstName}` 
      : `a ${grade} student`;

    const prompt = `You are an expert early literacy curriculum writer. 
    Write a short DECODABLE PASSAGE for ${studentContext} with these requirements:
    - Focus on: ${focusSounds}
    - Interest/Theme: ${interest}
    - Grade Level: ${grade}
    - Ensure the vocabulary is strictly decodable based on typical ${grade} progression.`;

    try {
      const response = await generateAIContent(prompt);
      setResult(response);
    } catch (error) {
      toast.error("Failed to generate passage.");
    } finally {
      setGenerating(false);
    }
  }

  return (
    <div className="p-6 max-w-4xl mx-auto space-y-6">
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        {/* Student Dropdown */}
        <div>
          <label className="block text-sm font-medium mb-1 text-slate-700">
            Personalize for Student (Optional)
          </label>
          <select 
            className="w-full p-2 border rounded-md bg-white"
            onChange={(e) => {
              const student = students.find(s => s.id === e.target.value);
              setSelectedStudent(student || null);
            }}
            value={selectedStudent?.id || ""}
          >
            <option value="">— No student selected —</option>
            {students.map(student => (
              <option key={student.id} value={student.id}>{student.firstName}</option>
            ))}
          </select>
        </div>

        <div>
          <label className="block text-sm font-medium mb-1 text-slate-700">Grade Level</label>
          <select className="w-full p-2 border rounded-md bg-white" value={grade} onChange={(e) => setGrade(e.target.value)}>
            <option>Kindergarten</option>
            <option>1st Grade</option>
            <option>2nd Grade</option>
          </select>
        </div>

        <div>
          <label className="block text-sm font-medium mb-1 text-slate-700">Focus Sounds</label>
          <Input value={focusSounds} onChange={(e) => setFocusSounds(e.target.value)} placeholder="e.g. short a, ch, th" />
        </div>

        <div>
          <label className="block text-sm font-medium mb-1 text-slate-700">Interest/Theme</label>
          <Input value={interest} onChange={(e) => setInterest(e.target.value)} placeholder="e.g. Space, Dogs" />
        </div>
      </div>

      <Button onClick={handleGenerate} disabled={generating} className="w-full">
        {generating ? "Crafting Passage..." : "Generate Decodable Passage"}
      </Button>

      {/* 3. Editable Result Area */}
      {result && (
        <div className="mt-6 p-4 border rounded-lg bg-slate-50 shadow-sm border-blue-100">
          <label className="block text-sm font-bold text-slate-700 mb-2">
            Generated Passage (Edit to refine)
          </label>
          <textarea
            className="w-full h-64 p-4 border rounded-md bg-white text-lg leading-relaxed focus:ring-2 focus:ring-blue-500 font-serif"
            value={result}
            onChange={(e) => setResult(e.target.value)}
          />
          <div className="mt-4 flex justify-end gap-3">
            <Button variant="outline" onClick={() => window.print()}>Print</Button>
            <Button onClick={() => toast.success("Saved to Lab!")}>Save to Lab</Button>
          </div>
        </div>
      )}
    </div>
  );
}
