import { useState } from "react";
import { Sparkles, Printer, ScrollText, Users, Theater } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Label } from "@/components/ui/label";
import { Input } from "@/components/ui/input";
import { Slider } from "@/components/ui/slider";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { base44 } from "@/api/base44Client";
import { toast } from "sonner";

const NAVY = "#1A2B3C";
const SLATE = "#475569";

export default function ScriptGenerator() {
  const [grade, setGrade] = useState("Grade 5");
  const [theme, setTheme] = useState("");
  const [charCount, setCharCount] = useState(6);
  const [goal, setGoal] = useState("");
  const [generating, setGenerating] = useState(false);
  const [script, setScript] = useState(null);

  async function handleGenerate() {
    if (!theme.trim()) { toast.error("Please enter a topic or story."); return; }
    setGenerating(true);
    
    const prompt = `Write a comprehensive Reader's Theater script for ${grade} students.
    Topic/Story: ${theme}
    Learning Goal: ${goal}
    Number of Characters: ${charCount}
    
    STRICT FORMATTING RULES:
    1. LENGTH: Write a long, full-page script (minimum 400 words) with multiple scenes.
    2. CAST: Ensure exactly ${charCount} distinct characters have significant lines.
    3. STRUCTURE: Include a Title, Character List, Setting Description, and clear Dialogue.
    4. DIALOGUE: Format as CHARACTER NAME (in caps): [Line].
    5. DIRECTIONS: Put stage directions in (parentheses and italics).
    
    JSON SCHEMA:
    {
      "title": "Title",
      "setting": "Setting description",
      "characters": ["Name 1", "Name 2"],
      "content": "Full script text with line breaks"
    }`;

    try {
      const res = await base44.integrations.Core.InvokeLLM({
        prompt,
        response_json_schema: {
          type: "object",
          properties: {
            title: { type: "string" },
            setting: { type: "string" },
            characters: { type: "array", items: { type: "string" } },
            content: { type: "string" }
          },
          required: ["title", "setting", "characters", "content"]
        }
      });
      setScript(res);
    } catch (e) {
      toast.error("Failed to generate script.");
    } finally {
      setGenerating(false);
    }
  }

  return (
    <div className="max-w-5xl mx-auto p-6 space-y-8">
      {/* --- Control Panel --- */}
      <div className="bg-white rounded-3xl p-8 border shadow-sm no-print space-y-6">
        <div className="flex items-center gap-3 border-b pb-4">
          <Theater className="w-6 h-6" style={{ color: NAVY }} />
          <h2 className="text-2xl font-bold" style={{ color: NAVY }}>Script Lab</h2>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div className="space-y-4">
            <div className="space-y-2">
              <Label className="text-slate-600 font-semibold">Grade Level</Label>
              <Select value={grade} onValueChange={setGrade}>
                <SelectTrigger className="rounded-xl border-slate-200 shadow-sm"><SelectValue /></SelectTrigger>
                <SelectContent>
                  {["Grade 3", "Grade 4", "Grade 5", "Grade 6"].map(g => <SelectItem key={g} value={g}>{g}</SelectItem>)}
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-2">
              <Label className="text-slate-600 font-semibold">Number of Characters ({charCount})</Label>
              <Slider 
                value={[charCount]} 
                onValueChange={(v) => setCharCount(v[0])} 
                min={2} 
                max={12} 
                step={1} 
                className="py-4"
              />
              <p className="text-[10px] text-slate-400 uppercase tracking-wider text-right font-bold">Cast size: {charCount} roles</p>
            </div>
          </div>

          <div className="space-y-4">
            <div className="space-y-2">
              <Label className="text-slate-600 font-semibold">Script Topic or Story</Label>
              <Input 
                value={theme} 
                onChange={(e) => setTheme(e.target.value)} 
                placeholder="e.g., The Water Cycle, The Boston Tea Party, or a specific story" 
                className="rounded-xl border-slate-200 shadow-sm focus:ring-2 focus:ring-navy/10"
              />
            </div>
            <div className="space-y-2">
              <Label className="text-slate-600 font-semibold">Learning Focus (Optional)</Label>
              <Input 
                value={goal} 
                onChange={(e) => setGoal(e.target.value)} 
                placeholder="e.g., Identifying theme, personification, or historical facts" 
                className="rounded-xl border-slate-200 shadow-sm focus:ring-2 focus:ring-navy/10"
              />
            </div>
          </div>
        </div>

        <Button 
          onClick={handleGenerate} 
          disabled={generating}
          className="w-full h-12 text-white rounded-2xl text-lg font-bold shadow-lg hover:opacity-90 hover:scale-[1.01] active:scale-[0.99] transition-all"
          style={{ backgroundColor: NAVY }}
        >
          {generating ? (
            <span className="flex items-center gap-2"><RefreshCw className="animate-spin w-5 h-5" /> Casting Roles...</span>
          ) : (
            <span className="flex items-center gap-2"><Sparkles className="w-5 h-5" /> Generate Full Script</span>
          )}
        </Button>
      </div>

      {/* --- Script Preview --- */}
      {script && (
        <div id="printable-script" className="bg-white rounded-sm border-2 shadow-2xl overflow-hidden transition-all duration-500 animate-in fade-in slide-in-from-bottom-4">
          {/* Internal Print Styles */}
          <style>{`
            @media print {
              body * { visibility: hidden; }
              #printable-script, #printable-script * { visibility: visible !important; }
              #printable-script { position: absolute; left: 0; top: 0; width: 100%; border: none !important; box-shadow: none !important; }
              .no-print { display: none !important; }
              @page { margin: 0.75in; size: letter; }
            }
          `}</style>

          <div className="p-12 space-y-8" style={{ fontFamily: "'Courier Prime', 'Courier New', monospace" }}>
            <div className="text-center space-y-2 border-b-2 pb-8 border-slate-100">
              <h1 className="text-4xl font-bold uppercase tracking-tighter" style={{ color: NAVY }}>{script.title}</h1>
              <p className="text-slate-400 font-bold uppercase tracking-widest text-xs">A Reader's Theater Script for {grade}</p>
            </div>

            <div className="grid grid-cols-3 gap-8">
              <div className="col-span-1 border-r pr-8 space-y-4">
                <h4 className="text-xs font-black uppercase tracking-widest text-slate-400 flex items-center gap-2">
                  <Users className="w-3 h-3" /> Cast of Characters
                </h4>
                <ul className="text-sm space-y-2 font-bold italic">
                  {script.characters.map(c => <li key={c} style={{ color: SLATE }}>{c}</li>)}
                </ul>
              </div>

              <div className="col-span-2 space-y-4">
                <h4 className="text-xs font-black uppercase tracking-widest text-slate-400 flex items-center gap-2">
                  <ScrollText className="w-3 h-3" /> Scene Setting
                </h4>
                <p className="text-sm italic leading-relaxed text-slate-600">
                  {script.setting}
                </p>
              </div>
            </div>

            <div className="pt-8 text-[1.05rem] leading-loose whitespace-pre-wrap text-slate-800 border-t border-slate-100">
              {script.content}
            </div>
          </div>
          
          <div className="bg-slate-50 p-6 border-t flex justify-center no-print">
            <Button 
              variant="outline" 
              onClick={() => window.print()} 
              className="rounded-full gap-2 px-8 py-6 text-base font-bold border-2 hover:bg-white transition-all shadow-sm"
              style={{ color: NAVY, borderColor: NAVY }}
            >
              <Printer className="w-5 h-5" /> Print Script for Class
            </Button>
          </div>
        </div>
      )}
    </div>
  );
}

const RefreshCw = ({ className }) => (
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
);
