import { useState, useRef } from "react";
import { CircleDot, Shuffle, Printer, BookmarkPlus, RefreshCw } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Label } from "@/components/ui/label";
import { Slider } from "@/components/ui/slider";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { Textarea } from "@/components/ui/textarea";
import { base44 } from "@/api/base44Client";
import { toast } from "sonner";
import ElkoninWorksheetPreview from "./elkonin/ElkoninWorksheetPreview";


const WORD_BANK = {
  "Grade K": ["cat", "dog", "sun", "hat", "big", "cup", "sit", "red", "hot", "map", "leg", "bug", "win", "top", "fun"],
  "Grade 1": ["ship", "frog", "blend", "clap", "flag", "grin", "snap", "trip", "drum", "plug", "stem", "crisp", "flat", "grip", "slim"],
  "Grade 2": ["blend", "crunch", "splash", "spring", "stream", "shrimp", "bright", "stroll", "crisp", "sprint", "scrub", "strap", "shrink", "twist", "frost"],
};


function pickRandom(arr, n) {
  const shuffled = [...arr].sort(() => Math.random() - 0.5);
  return shuffled.slice(0, n);
}


export default function ElkoninBoxesGenerator() {
  const [grade, setGrade] = useState("Grade K");
  const [boxCount, setBoxCount] = useState(3);
  const [visualStyle, setVisualStyle] = useState("standard");
  const [wordInput, setWordInput] = useState("");
  const [words, setWords] = useState(null);
  const [showAnswerKey, setShowAnswerKey] = useState(false);
  const [saving, setSaving] = useState(false);


  function handleGenerateRandom() {
    const picked = pickRandom(WORD_BANK[grade], 8);
    setWordInput(picked.join("\n"));
  }


  function handleGenerate() {
    const parsed = wordInput
      .split("\n")
      .map(w => w.replace(/\*\*/g, "").replace(/^#+\s*/g, "").trim().toLowerCase())
      .filter(w => w.length > 0);
    if (parsed.length === 0) {
      toast.error("Please enter at least one word.");
      return;
    }
    setWords(parsed);
  }


  async function handleSaveToActivities() {
    setSaving(true);
    await base44.entities.Activity.create({
      title: `Elkonin Boxes – ${grade} (${boxCount} boxes)`,
      type: "Worksheet",
      grade,
      subject: "ELA",
      content: words.join(", "),
      source_tool: "Elkonin Boxes Generator",
    });
    setSaving(false);
    toast.success("Success! This resource is now available in your Skill Builders library.");
  }


  function handleReset() {
    setWords(null);
  }


  return (
    <div className="space-y-6">
      {/* Config Card */}
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-border/50">
        <div className="flex items-center gap-3 mb-6">
          <div className="w-10 h-10 rounded-xl bg-newton-green flex items-center justify-center">
            <CircleDot className="w-5 h-5 text-white" />
          </div>
          <div>
            <h2 className="font-display font-bold text-xl text-newton-pink">Elkonin Boxes Generator</h2>
            <p className="text-sm text-muted-foreground">Segment words into phonemes with printable sound boxes</p>
          </div>
        </div>


        <div className="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
          {/* Word Input */}
          <div className="space-y-2 sm:col-span-2">
            <div className="flex items-center justify-between">
              <Label className="text-sm font-semibold">Target Words (one per line)</Label>
              <div className="flex items-center gap-2">
                <Select value={grade} onValueChange={setGrade}>
                  <SelectTrigger className="w-28 h-8 text-xs rounded-lg border-border/60">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    {Object.keys(WORD_BANK).map(g => <SelectItem key={g} value={g}>{g}</SelectItem>)}
                  </SelectContent>
                </Select>
                <Button
                  variant="outline"
                  size="sm"
                  onClick={handleGenerateRandom}
                  className="rounded-lg gap-1.5 text-xs border-newton-green/50 text-newton-green hover:bg-newton-green/10 h-8"
                >
                  <Shuffle className="w-3.5 h-3.5" /> Random Words
                </Button>
              </div>
            </div>
            <Textarea
              value={wordInput}
              onChange={e => setWordInput(e.target.value)}
              placeholder={"cat\ndog\nsun\nship\nfrog"}
              rows={6}
              className="rounded-xl border-border/60 font-mono text-sm"
            />
          </div>


          {/* Box Count */}
          <div className="space-y-3">
            <Label className="text-sm font-semibold">
              Boxes Per Word: <span className="text-newton-pink font-bold">{boxCount}</span>
            </Label>
            <div className="px-1 pt-1">
              <Slider
                min={2}
                max={5}
                step={1}
                value={[boxCount]}
                onValueChange={([v]) => setBoxCount(v)}
              />
              <div className="flex justify-between text-xs text-muted-foreground mt-1">
                <span>2</span><span>3</span><span>4</span><span>5</span>
              </div>
            </div>
            <p className="text-xs text-muted-foreground">Students place tokens (coins/chips) in each box as they say each sound.</p>
          </div>


          {/* Answer Key Toggle */}
          <div className="space-y-3">
            <Label className="text-sm font-semibold">Answer Key</Label>
            <div className="flex items-center justify-between p-3 bg-secondary/30 border border-border/40 rounded-xl">
              <div>
                <p className="text-sm font-semibold text-foreground">Show Letters in Boxes</p>
                <p className="text-xs text-muted-foreground">OFF = blank boxes for students</p>
              </div>
              <button
                role="switch"
                aria-checked={showAnswerKey}
                onClick={() => setShowAnswerKey(v => !v)}
                className={`w-10 h-6 rounded-full transition-colors duration-200 relative shrink-0 ${showAnswerKey ? "bg-newton-pink" : "bg-border"}`}
              >
                <div className={`absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200 ${showAnswerKey ? "translate-x-4" : ""}`} />
              </button>
            </div>
          </div>


          {/* Visual Style */}
          <div className="space-y-3">
            <Label className="text-sm font-semibold">Box Style</Label>
            <div className="flex gap-2">
              {["standard", "dot"].map(s => (
                <button
                  key={s}
                  onClick={() => setVisualStyle(s)}
                  className={`flex-1 py-2.5 px-4 rounded-xl text-sm font-semibold border-2 transition-all ${
                    visualStyle === s
                      ? "border-newton-pink bg-newton-pink text-white shadow-md"
                      : "border-border/50 text-muted-foreground hover:border-newton-pink/40"
                  }`}
                >
                  {s === "standard" ? "□ Standard" : "⊙ Dot Boxes"}
                </button>
              ))}
            </div>
            <p className="text-xs text-muted-foreground">
              {visualStyle === "dot" ? "Each box has a small dot — students tap it as they say each phoneme." : "Plain empty boxes for token placement."}
            </p>
          </div>
        </div>


        {/* Generate Button */}
        <div className="flex justify-end">
          {words && (
            <Button onClick={handleReset} variant="outline" className="rounded-full gap-2 border-border/60 mr-2">
              <RefreshCw className="w-4 h-4" /> Reset
            </Button>
          )}
          <Button
            onClick={handleGenerate}
            className="rounded-full bg-newton-pink hover:bg-newton-pink/90 text-white shadow-md shadow-newton-pink/30 px-6 gap-2"
          >
            <CircleDot className="w-4 h-4" />
            Generate Worksheet
          </Button>
        </div>
      </div>


      {/* Empty State */}
      {!words && (
        <div className="bg-white rounded-2xl border-2 border-dashed border-border/50 flex flex-col items-center justify-center py-16 px-6 text-center">
          <div className="w-16 h-16 rounded-2xl bg-newton-green/10 flex items-center justify-center mb-4">
            <CircleDot className="w-8 h-8 text-newton-green" />
          </div>
          <h3 className="font-display font-semibold text-lg mb-2">Ready to generate</h3>
          <p className="text-sm text-muted-foreground max-w-sm">
            Enter words or click <strong>Random Words</strong>, then click <strong>Generate Worksheet</strong>.
          </p>
        </div>
      )}


      {/* Worksheet */}
      {words && (
        <div className="space-y-4">
          <div className="flex items-center justify-between flex-wrap gap-3">
            <div className="flex items-center gap-2 text-sm text-muted-foreground">
              <span className="font-medium text-foreground">{words.length} words</span> · <span>{boxCount} boxes each</span>
            </div>
            <div className="flex gap-2">
              <Button
                onClick={handleSaveToActivities}
                disabled={saving}
                variant="outline"
                className="rounded-full gap-2 border-newton-pink/60 text-newton-pink hover:bg-newton-pink/10"
              >
                <BookmarkPlus className="w-4 h-4" />
                {saving ? "Saving..." : "Add to Skill Builders"}
              </Button>
              <Button
                onClick={() => window.print()}
                variant="outline"
                className="rounded-full gap-2 border-border/60"
              >
                <Printer className="w-4 h-4" /> Print / Save PDF
              </Button>
            </div>
          </div>


          <ElkoninWorksheetPreview words={words} boxCount={boxCount} visualStyle={visualStyle} showAnswerKey={showAnswerKey} />
        </div>
      )}
    </div>
  );
}

