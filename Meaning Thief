import { useState } from "react";
import { Printer, BookmarkPlus, Edit3, Check } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { base44 } from "@/api/base44Client";
import { toast } from "sonner";

const NAVY = "#1A2B3C";
const GRADES = ["Kindergarten", "Grade 1", "Grade 2", "Grade 3", "Grade 4", "Grade 5"];

export default function ClozePassageGenerator() {
  const [grade, setGrade] = useState("Grade 5");
  const [theme, setTheme] = useState("");
  const [generating, setGenerating] = useState(false);
  const [passage, setPassage] = useState(null);
  const [isEditing, setIsEditing] = useState(false);
  const [answers, setAnswers] = useState({});

async function handleGenerate() {
    if (!theme.trim()) { toast.error("Please enter a theme."); return; }
    setGenerating(true);
    setPassage(null);
    setAnswers({});
    setIsEditing(false);

    const prompt = `Create a DIBELS-aligned educational passage for ${grade} about "${theme}".
    
    STRICT CHALLENGE RULES:
    1. QUANTITY: You MUST generate EXACTLY 6 cloze items.
    2. THREE OPTIONS: Every single item MUST have 3 unique choices: "correct", "phonetic", and "semantic". 
    3. NO DUPLICATES: All 3 options for an item must be different real words.
    4. CONTINUITY: The 6 items must form a single, 150-word cohesive story. The "after" of one item must flow perfectly into the "before" of the next.
    5. NO SYLLABLES: Use whole words only (e.g., "discovery" NOT "dis-cov-ery").
    
    JSON SCHEMA:
    {
      "title": "Title",
      "items": [
        {
          "before": "Start of sentence ",
          "correct": "WordA",
          "after": " middle of sentence ",
          "phonetic": "WordB",
          "semantic": "WordC"
        }
      ]
    }`;

    try {
      const res = await base44.integrations.Core.InvokeLLM({
        prompt,
        response_json_schema: {
          type: "object",
          properties: {
            title: { type: "string" },
            items: {
              type: "array",
              minItems: 6,
              maxItems: 6,
              items: {
                type: "object",
                properties: {
                  before: { type: "string" },
                  after: { type: "string" },
                  correct: { type: "string", pattern: "^[^\\-]+$" },
                  phonetic: { type: "string", pattern: "^[^\\-]+$" },
                  semantic: { type: "string", pattern: "^[^\\-]+$" }
                },
                required: ["before", "after", "correct", "phonetic", "semantic"]
              }
            }
          },
          required: ["title", "items"]
        }
      });
      setPassage(res);
    } catch (e) {
      toast.error("The Thief escaped! Try generating again.");
    } finally {
      setGenerating(false);
    }
  }

  const handleSave = async () => {
    if (!passage) return;
    try {
      await base44.storage.create("AIContent", {
        title: passage.title,
        type: "Cloze Passage",
        content: JSON.stringify(passage),
        grade
      });
      toast.success("Saved to Library!");
    } catch (e) {
      toast.error("Save failed.");
    }
  };

  const updateItem = (idx, key, val) => {
    const next = [...passage.items];
    next[idx][key] = val;
    setPassage({ ...passage, items: next });
  };

  return (
    <div className="space-y-6 max-w-4xl mx-auto p-4">
      <style>{`
        @media print {
          body * { visibility: hidden; }
          #printable-content, #printable-content * { visibility: visible !important; }
          #printable-content { position: absolute; left: 0; top: 0; width: 100%; }
          .no-print { display: none !important; }
        }
      `}</style>

      <div className="bg-white rounded-2xl p-6 shadow-sm border no-print">
        <h2 className="text-xl font-bold mb-4" style={{ color: NAVY }}>The Meaning Thief</h2>
        <div className="grid grid-cols-2 gap-4 mb-4">
          <div className="space-y-2">
            <Label>Grade Level</Label>
            <Select value={grade} onValueChange={setGrade}>
              <SelectTrigger className="rounded-xl"><SelectValue /></SelectTrigger>
              <SelectContent>{GRADES.map(g => <SelectItem key={g} value={g}>{g}</SelectItem>)}</SelectContent>
            </Select>
          </div>
          <div className="space-y-2">
            <Label>Theme</Label>
            <Input value={theme} onChange={e => setTheme(e.target.value)} placeholder="e.g. Ocean Life" className="rounded-xl" />
          </div>
        </div>
        <Button onClick={handleGenerate} disabled={generating} className="w-full text-white rounded-xl" style={{ backgroundColor: NAVY }}>
          {generating ? "Catching the Thief..." : "Generate Cloze Passage"}
        </Button>
      </div>

      {passage && (
        <div id="printable-content" className="space-y-4">
          <div className="flex justify-between items-center no-print px-2">
            <h3 className="text-lg font-bold" style={{ color: NAVY }}>{passage.title}</h3>
            <div className="flex gap-2">
              <Button variant="outline" size="sm" onClick={handleSave} className="rounded-full"><BookmarkPlus className="w-4 h-4 mr-1" /> Save</Button>
              <Button variant="outline" size="sm" onClick={() => window.print()} className="rounded-full"><Printer className="w-4 h-4 mr-1" /> Print</Button>
              <Button variant="outline" size="sm" onClick={() => setIsEditing(!isEditing)} className="rounded-full">
                {isEditing ? <><Check className="w-4 h-4 mr-1" /> Finish</> : <><Edit3 className="w-4 h-4 mr-1" /> Edit</>}
              </Button>
            </div>
          </div>

          <div className="bg-white rounded-3xl p-10 border shadow-sm" style={{ fontFamily: "'Comic Neue', cursive", fontSize: "1.3rem", lineHeight: "3.5" }}>
            {passage.items.map((item, idx) => (
              <span key={idx} className="inline">
                {isEditing ? (
                  <div className="inline-flex flex-col border-2 border-blue-100 p-2 rounded-lg bg-blue-50/20 mx-1 align-top mb-4 no-print">
                    <textarea className="text-xs p-1 w-full bg-transparent border-b" value={item.before} onChange={e => updateItem(idx, 'before', e.target.value)} />
                    <div className="flex gap-1 py-1">
                       <input className="font-bold border px-1 w-24 text-xs" value={item.correct} onChange={e => updateItem(idx, 'correct', e.target.value)} />
                       <input className="border px-1 w-24 text-xs" value={item.phonetic} onChange={e => updateItem(idx, 'phonetic', e.target.value)} />
                       <input className="border px-1 w-24 text-xs" value={item.semantic} onChange={e => updateItem(idx, 'semantic', e.target.value)} />
                    </div>
                    <textarea className="text-xs p-1 w-full bg-transparent border-t" value={item.after} onChange={e => updateItem(idx, 'after', e.target.value)} />
                  </div>
                ) : (
                  <Segment item={item} answered={answers[idx]} onAnswer={val => setAnswers({...answers, [idx]: val})} />
                )}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

function Segment({ item, answered, onAnswer }) {
  // We filter out duplicates just in case the AI ignores the prompt
  const uniqueChoices = Array.from(new Set([item.correct, item.phonetic, item.semantic])).sort();

  return (
    <>
      <span className="whitespace-pre-wrap">{item.before}</span>
      {answered ? (
        <span className={`inline-block px-3 py-0 rounded-lg font-bold text-white mx-1 align-baseline ${answered === item.correct ? 'bg-teal-600' : 'bg-red-500'}`} style={{ lineHeight: '1.4' }}>
          {answered}
        </span>
      ) : (
        <span className="inline-flex flex-nowrap items-center gap-2 mx-1 px-3 py-1.5 bg-slate-100 border-b-2 border-slate-400 rounded-t-xl no-print align-middle shadow-inner">
          {uniqueChoices.map(choice => (
            <button 
              key={choice} 
              onClick={() => onAnswer(choice)} 
              className="text-[12px] font-bold px-3 py-1 bg-white border border-slate-300 rounded-lg hover:border-blue-500 hover:text-blue-700 shadow-sm transition-all leading-none whitespace-nowrap"
            >
              {choice}
            </button>
          ))}
        </span>
      )}
      {!answered && <span className="hidden print:inline-block border-b-2 border-black w-28 mx-1" />}
      <span className="whitespace-pre-wrap">{item.after}</span>
    </>
  );
}



